# Backend Environment Variables
# Copy this file to .env and fill in your values

# ── Blockchain ───────────────────────────────────────────────────────────────
# Local Hardhat node (default) or Sepolia RPC
RPC_URL=http://127.0.0.1:8545

# Paste the contract address printed by the deploy script
CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# Admin wallet private key (WITHOUT 0x prefix) — used to sign transactions
# ⚠️  NEVER commit the actual .env to git
PRIVATE_KEY=your_private_key_without_0x

# Admin wallet address (corresponding to the private key above)
ADMIN_ADDRESS=0xYourAdminWalletAddress

# ── OCR ──────────────────────────────────────────────────────────────────────
# Path to Tesseract executable
# Windows default: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Mac:       /usr/bin/tesseract
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
